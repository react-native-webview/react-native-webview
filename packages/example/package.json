    "start": "react-native start"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-native": "0.83.4",
    "react-native-webview": "workspace:*"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.4",
    "@react-native/metro-config": "0.83.4",
    "@rnx-kit/metro-config": "^1.3.15",
    "@callstack/react-native-visionos": "0.79.6",
    "react-native-macos": "0.81.4",
    "react-native-test-app": "^3.7.2",
    "react-native-windows": "0.82.1"
  }
}
