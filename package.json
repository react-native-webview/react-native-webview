{
  "name": "react-native-webview-monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "nohoist": [
      "example-windows/**",
      "example-macos/**"
    ]
  },
  "scripts": {
    "build": "bun run --cwd packages/react-native-webview build",
    "tsc": "bun run --cwd packages/react-native-webview lint:tsgo",
    "prepare": "bun run --cwd packages/react-native-webview prepare",
    "lint": "bun run --cwd packages/react-native-webview lint",
    "lint:ci": "bun run --cwd packages/react-native-webview lint:ci",
    "test:windows": "bun run --cwd packages/react-native-webview test:windows",
    "ci:publish": "bun run --cwd packages/react-native-webview ci:publish",
    "start": "bun run --cwd packages/example-mobile start",
    "android": "bun run --cwd packages/example-mobile android",
    "ios": "bun run --cwd packages/example-mobile ios",
    "macos": "bun run --cwd packages/example-macos macos",
    "windows": "bun run --cwd packages/example-windows windows"
  }
}
